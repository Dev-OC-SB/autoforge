# Docker Environment Configuration
# =================================
# Copy this file to .env in the same directory as docker-compose.yml
# and customize the values for your deployment.

# Provider Selection
# ------------------
# Options: auto, ollama, openrouter, openai
# "auto" will select the first available provider
AUTOFORGE_PROVIDER=auto

# OpenRouter Configuration
# -------------------------
# Get your API key from: https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Ollama Configuration
# --------------------
# Ollama runs in a separate container
# The base URL should point to the ollama service
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=codellama:13b

# OpenAI Configuration
# --------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: N8N Webhook
# ---------------------
PROGRESS_N8N_WEBHOOK_URL=

# Note: After starting the containers, you need to pull Ollama models:
# docker exec -it autoforge-ollama ollama pull codellama:13b
# docker exec -it autoforge-ollama ollama pull qwen2.5-coder:32b
